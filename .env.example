# Required if using a real LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local GGUF model, preferred for no-key lab runs
LOCAL_LLM_ENABLED=true
LOCAL_MODEL_PATH=WEIGHT/Qwen_Qwen3.5-0.8B-Q4_K_M.gguf
LOCAL_MODEL_N_CTX=2048
LOCAL_MODEL_N_GPU_LAYERS=-1
LOCAL_MODEL_MAX_TOKENS=512
LOCAL_MODEL_TEMPERATURE=0.2

# Optional tracing providers
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=multi-agent-research-lab
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional search provider
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
